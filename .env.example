# --- Core ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/world_cup
ADMIN_EMAILS=you@example.com,other@example.com

# --- Better Auth ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Auto result sync (cron) ---
# Shared secret the cron endpoint requires as `Authorization: Bearer <secret>`.
# Set the same value in Vercel and in your Upstash QStash schedule headers.
CRON_SECRET=

# API-Football (api-sports.io) — live results feed.
API_FOOTBALL_KEY=
# Competition id (FIFA World Cup = 1) and season year. Defaults: 1 / 2026.
API_FOOTBALL_LEAGUE=1
API_FOOTBALL_SEASON=2026
